%% -*- mode: erlang -*-
%%
%% This plugin is an umbrella app of the EMQX monorepo — it is discovered
%% via `project_app_dirs/1` in the root `rebar.config.erl` and compiled
%% by the root `make`. CT runs via `make plugins/emqx_relup-ct`
%% (handled by the generic `gen-app-ct-target` rule).
%%
%% Packaging is driven entirely from the umbrella build: `make
%% plugin-emqx_relup` hands off to `scripts/package-plugin.escript`,
%% which reads the `emqx_plugrel` metadata block below and the
%% already-compiled beams from `_build/$PROFILE/lib/emqx_relup/` to
%% produce `_build/plugins/emqx_relup-<vsn>.tar.gz`.
%%
%% Standalone `rebar3` builds are not supported — the plugin is built
%% only through the umbrella, so this file omits `relx` and build
%% plugins.

{emqx_plugrel, [
    {authors, ["EMQX"]},
    {builder, [
        {name, "EMQX"},
        {contact, "developer@emqx.io"},
        {website, "https://www.emqx.com"}
    ]},
    {repo, "https://github.com/emqx/emqx"},
    {functionality, ["Hot upgrade"]},
    {compatibility, [{emqx, "~> 5.10"}]},
    {description, "EMQX hot-upgrade (relup) plugin."}
]}.
