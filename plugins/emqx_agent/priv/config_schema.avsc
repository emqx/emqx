{
  "type": "record",
  "name": "AgentConfig",
  "fields": [
    {
      "name": "tools",
      "type": {
        "type": "array",
        "items": [
          {
            "type": "record",
            "name": "Message_Publish",
            "fields": [
              {"name": "type", "type": {"type": "enum", "name": "Message_PublishType", "symbols": ["message__publish"]}, "default": "message__publish", "description": "$tool_type_desc"},
              {"name": "id", "type": "string", "description": "$tool_id_desc"},
              {"name": "desc", "type": "string", "description": "$tool_desc_desc"},
              {"name": "topic_prefix", "type": "string", "description": "$tool_topic_prefix_desc"},
              {"name": "payload_schema", "type": "string", "default": "{\"type\":\"object\",\"properties\":{\"message\":{\"type\":\"string\"}},\"required\":[\"message\"],\"additionalProperties\":false}", "description": "$tool_payload_schema_desc"}
            ]
          },
          {
            "type": "record",
            "name": "Message_Request",
            "fields": [
              {"name": "type", "type": {"type": "enum", "name": "Message_RequestType", "symbols": ["message__request"]}, "default": "message__request", "description": "$tool_type_desc"},
              {"name": "id", "type": "string", "description": "$tool_id_desc"},
              {"name": "desc", "type": "string", "description": "$tool_desc_desc"},
              {"name": "topic_prefix", "type": "string", "description": "$tool_topic_prefix_desc"},
              {"name": "request_payload_schema", "type": "string", "default": "", "description": "$tool_request_payload_schema_desc"}
            ]
          },
          {
            "type": "record",
            "name": "Http",
            "fields": [
              {"name": "type", "type": {"type": "enum", "name": "HttpType", "symbols": ["http"]}, "default": "http", "description": "$tool_type_desc"},
              {"name": "id", "type": "string", "description": "$tool_id_desc"},
              {"name": "desc", "type": "string", "description": "$tool_desc_desc"},
              {"name": "method", "type": {"type": "enum", "name": "HttpMethod", "symbols": ["get", "post", "put", "patch", "delete"]}, "description": "$tool_http_method_desc"},
              {"name": "url", "type": "string", "description": "$tool_http_url_desc"},
              {"name": "headers", "type": {"type": "array", "items": {"type": "record", "name": "NameValueEntry", "fields": [{"name": "name", "type": "string", "description": "$name_value_name_desc"}, {"name": "value", "type": "string", "description": "$name_value_value_desc"}]}}, "default": [], "description": "$tool_http_headers_desc"},
              {"name": "input_schema", "type": "string", "description": "$tool_input_schema_desc"}
            ]
          },
          {
            "type": "record",
            "name": "Postgresql_Query",
            "fields": [
              {"name": "type", "type": {"type": "enum", "name": "Postgresql_QueryType", "symbols": ["postgresql__query"]}, "default": "postgresql__query", "description": "$tool_type_desc"},
              {"name": "id", "type": "string", "description": "$tool_id_desc"},
              {"name": "desc", "type": "string", "description": "$tool_desc_desc"},
              {"name": "query", "type": "string", "description": "$tool_pg_query_desc"},
              {"name": "resource", "type": "string", "description": "$tool_pg_resource_desc"}
            ]
          },
          {
            "type": "record",
            "name": "StreamWrite",
            "fields": [
              {"name": "type", "type": {"type": "enum", "name": "StreamWriteType", "symbols": ["stream_write"]}, "default": "stream_write", "description": "$tool_type_desc"},
              {"name": "id", "type": "string", "description": "$tool_id_desc"},
              {"name": "desc", "type": "string", "description": "$tool_desc_desc"},
              {"name": "stream", "type": "string", "description": "$tool_stream_desc"},
              {"name": "format", "type": "string", "default": "json", "description": "$tool_format_desc"}
            ]
          },
          {
            "type": "record",
            "name": "StreamRead",
            "fields": [
              {"name": "type", "type": {"type": "enum", "name": "StreamReadType", "symbols": ["stream_read"]}, "default": "stream_read", "description": "$tool_type_desc"},
              {"name": "id", "type": "string", "description": "$tool_id_desc"},
              {"name": "desc", "type": "string", "description": "$tool_desc_desc"},
              {"name": "stream", "type": "string", "description": "$tool_stream_desc"},
              {"name": "format", "type": "string", "default": "json", "description": "$tool_format_desc"}
            ]
          },
          {
            "type": "record",
            "name": "StreamDel",
            "fields": [
              {"name": "type", "type": {"type": "enum", "name": "StreamDelType", "symbols": ["stream_del"]}, "default": "stream_del", "description": "$tool_type_desc"},
              {"name": "id", "type": "string", "description": "$tool_id_desc"},
              {"name": "desc", "type": "string", "description": "$tool_desc_desc"},
              {"name": "stream", "type": "string", "description": "$tool_stream_desc"}
            ]
          },
          {
            "type": "record",
            "name": "KvWrite",
            "fields": [
              {"name": "type", "type": {"type": "enum", "name": "KvWriteType", "symbols": ["kv_write"]}, "default": "kv_write", "description": "$tool_type_desc"},
              {"name": "id", "type": "string", "description": "$tool_id_desc"},
              {"name": "desc", "type": "string", "description": "$tool_desc_desc"},
              {"name": "stream", "type": "string", "description": "$tool_stream_desc"},
              {"name": "format", "type": "string", "default": "json", "description": "$tool_format_desc"}
            ]
          },
          {
            "type": "record",
            "name": "KvRead",
            "fields": [
              {"name": "type", "type": {"type": "enum", "name": "KvReadType", "symbols": ["kv_read"]}, "default": "kv_read", "description": "$tool_type_desc"},
              {"name": "id", "type": "string", "description": "$tool_id_desc"},
              {"name": "desc", "type": "string", "description": "$tool_desc_desc"},
              {"name": "stream", "type": "string", "description": "$tool_stream_desc"},
              {"name": "format", "type": "string", "default": "json", "description": "$tool_format_desc"}
            ]
          },
          {
            "type": "record",
            "name": "KvReadAll",
            "fields": [
              {"name": "type", "type": {"type": "enum", "name": "KvReadAllType", "symbols": ["kv_read_all"]}, "default": "kv_read_all", "description": "$tool_type_desc"},
              {"name": "id", "type": "string", "description": "$tool_id_desc"},
              {"name": "desc", "type": "string", "description": "$tool_desc_desc"},
              {"name": "stream", "type": "string", "description": "$tool_stream_desc"},
              {"name": "format", "type": "string", "default": "json", "description": "$tool_format_desc"}
            ]
          },
          {
            "type": "record",
            "name": "KvDel",
            "fields": [
              {"name": "type", "type": {"type": "enum", "name": "KvDelType", "symbols": ["kv_del"]}, "default": "kv_del", "description": "$tool_type_desc"},
              {"name": "id", "type": "string", "description": "$tool_id_desc"},
              {"name": "desc", "type": "string", "description": "$tool_desc_desc"},
              {"name": "stream", "type": "string", "description": "$tool_stream_desc"}
            ]
          },
          {
            "type": "record",
            "name": "KvClear",
            "fields": [
              {"name": "type", "type": {"type": "enum", "name": "KvClearType", "symbols": ["kv_clear"]}, "default": "kv_clear", "description": "$tool_type_desc"},
              {"name": "id", "type": "string", "description": "$tool_id_desc"},
              {"name": "desc", "type": "string", "description": "$tool_desc_desc"},
              {"name": "stream", "type": "string", "description": "$tool_stream_desc"}
            ]
          },
          {
            "type": "record",
            "name": "Agent_CreateTool",
            "fields": [
              {"name": "type", "type": {"type": "enum", "name": "Agent_CreateToolType", "symbols": ["agent__create_tool"]}, "default": "agent__create_tool", "description": "$tool_type_desc"},
              {"name": "id", "type": "string", "description": "$tool_id_desc"}
            ]
          },
          {
            "type": "record",
            "name": "Agent_CreatePipeline",
            "fields": [
              {"name": "type", "type": {"type": "enum", "name": "Agent_CreatePipelineType", "symbols": ["agent__create_pipeline"]}, "default": "agent__create_pipeline", "description": "$tool_type_desc"},
              {"name": "id", "type": "string", "description": "$tool_id_desc"}
            ]
          },
          {
            "type": "record",
            "name": "Agent_QueryTools",
            "fields": [
              {"name": "type", "type": {"type": "enum", "name": "Agent_QueryToolsType", "symbols": ["agent__query_tools"]}, "default": "agent__query_tools", "description": "$tool_type_desc"},
              {"name": "id", "type": "string", "description": "$tool_id_desc"}
            ]
          },
          {
            "type": "record",
            "name": "Agent_QueryProviders",
            "fields": [
              {"name": "type", "type": {"type": "enum", "name": "Agent_QueryProvidersType", "symbols": ["agent__query_providers"]}, "default": "agent__query_providers", "description": "$tool_type_desc"},
              {"name": "id", "type": "string", "description": "$tool_id_desc"}
            ]
          },
          {
            "type": "record",
            "name": "Agent_QueryPipelines",
            "fields": [
              {"name": "type", "type": {"type": "enum", "name": "Agent_QueryPipelinesType", "symbols": ["agent__query_pipelines"]}, "default": "agent__query_pipelines", "description": "$tool_type_desc"},
              {"name": "id", "type": "string", "description": "$tool_id_desc"}
            ]
          },
          {
            "type": "record",
            "name": "Agent_DeleteTool",
            "fields": [
              {"name": "type", "type": {"type": "enum", "name": "Agent_DeleteToolType", "symbols": ["agent__delete_tool"]}, "default": "agent__delete_tool", "description": "$tool_type_desc"},
              {"name": "id", "type": "string", "description": "$tool_id_desc"}
            ]
          },
          {
            "type": "record",
            "name": "Agent_DeletePipeline",
            "fields": [
              {"name": "type", "type": {"type": "enum", "name": "Agent_DeletePipelineType", "symbols": ["agent__delete_pipeline"]}, "default": "agent__delete_pipeline", "description": "$tool_type_desc"},
              {"name": "id", "type": "string", "description": "$tool_id_desc"}
            ]
          },
          {
            "type": "record",
            "name": "Agent_QueryConnections",
            "fields": [
              {"name": "type", "type": {"type": "enum", "name": "Agent_QueryConnectionsType", "symbols": ["agent__query_connections"]}, "default": "agent__query_connections", "description": "$tool_type_desc"},
              {"name": "id", "type": "string", "description": "$tool_id_desc"}
            ]
          },
          {
            "type": "record",
            "name": "Agent_UpdateTool",
            "fields": [
              {"name": "type", "type": {"type": "enum", "name": "Agent_UpdateToolType", "symbols": ["agent__update_tool"]}, "default": "agent__update_tool", "description": "$tool_type_desc"},
              {"name": "id", "type": "string", "description": "$tool_id_desc"}
            ]
          },
          {
            "type": "record",
            "name": "Agent_UpdatePipeline",
            "fields": [
              {"name": "type", "type": {"type": "enum", "name": "Agent_UpdatePipelineType", "symbols": ["agent__update_pipeline"]}, "default": "agent__update_pipeline", "description": "$tool_type_desc"},
              {"name": "id", "type": "string", "description": "$tool_id_desc"}
            ]
          },
          {
            "type": "record",
            "name": "Agent_DeletePipelineStep",
            "fields": [
              {"name": "type", "type": {"type": "enum", "name": "Agent_DeletePipelineStepType", "symbols": ["agent__delete_pipeline_step"]}, "default": "agent__delete_pipeline_step", "description": "$tool_type_desc"},
              {"name": "id", "type": "string", "description": "$tool_id_desc"}
            ]
          },
          {
            "type": "record",
            "name": "Agent_InsertPipelineStep",
            "fields": [
              {"name": "type", "type": {"type": "enum", "name": "Agent_InsertPipelineStepType", "symbols": ["agent__insert_pipeline_step"]}, "default": "agent__insert_pipeline_step", "description": "$tool_type_desc"},
              {"name": "id", "type": "string", "description": "$tool_id_desc"}
            ]
          },
          {
            "type": "record",
            "name": "Agent_UpdatePipelineStep",
            "fields": [
              {"name": "type", "type": {"type": "enum", "name": "Agent_UpdatePipelineStepType", "symbols": ["agent__update_pipeline_step"]}, "default": "agent__update_pipeline_step", "description": "$tool_type_desc"},
              {"name": "id", "type": "string", "description": "$tool_id_desc"}
            ]
          }
        ]
      },
      "default": [],
      "description": "$tools_desc"
    },
    {
      "name": "connections",
      "type": {
        "type": "array",
        "items": [
          {
            "type": "record",
            "name": "ConnectionPostgresql",
            "fields": [
              {"name": "type", "type": {"type": "enum", "name": "ConnectionPostgresqlType", "symbols": ["postgresql"]}, "default": "postgresql", "description": "$connection_type_desc"},
              {"name": "id", "type": "string", "description": "$connection_id_desc"},
              {"name": "enable", "type": "boolean", "default": false, "description": "$connection_enable_desc"},
              {"name": "config", "type": {"type": "record", "name": "PostgresqlConnectionConfig", "fields": [
                {"name": "server", "type": "string", "description": "$pg_server_desc"},
                {"name": "database", "type": "string", "description": "$pg_database_desc"},
                {"name": "username", "type": "string", "description": "$pg_username_desc"},
                {"name": "password", "type": "string", "default": "", "description": "$pg_password_desc"},
                {"name": "pool_size", "type": "int", "default": 8, "description": "$pg_pool_size_desc"},
                {"name": "connect_timeout", "type": "int", "default": 15000, "description": "$pg_connect_timeout_desc"},
                {"name": "disable_prepared_statements", "type": "boolean", "default": false, "description": "$pg_disable_prepared_statements_desc"},
                {"name": "ssl", "type": {"type": "record", "name": "PostgresqlSSL", "fields": [
                  {"name": "enable", "type": "boolean", "default": false, "description": "$ssl_enable_desc"},
                  {"name": "server_name_indication", "type": "string", "default": "disable", "description": "$ssl_sni_desc"},
                  {"name": "verify", "type": "string", "default": "verify_none", "description": "$ssl_verify_desc"},
                  {"name": "cacertfile", "type": "string", "default": "", "description": "$ssl_cacertfile_desc"},
                  {"name": "certfile", "type": "string", "default": "", "description": "$ssl_certfile_desc"},
                  {"name": "keyfile", "type": "string", "default": "", "description": "$ssl_keyfile_desc"}
                ]}, "default": {"enable": false, "server_name_indication": "disable", "verify": "verify_none", "cacertfile": "", "certfile": "", "keyfile": ""}, "description": "$ssl_desc"}
              ]}, "description": "$connection_config_desc"}
            ]
          }
        ]
      },
      "default": [],
      "description": "$connections_desc"
    },
    {
      "name": "pipelines",
      "type": {"type": "array", "items": {"type": "record", "name": "Pipeline", "fields": [
        {"name": "pipeline_id", "type": "string", "description": "$pipeline_id_desc"},
        {"name": "active", "type": "boolean", "default": true, "description": "$pipeline_active_desc"},
        {"name": "trigger", "type": {"type": "record", "name": "PipelineTrigger", "fields": [
          {"name": "topic", "type": "string", "description": "$pipeline_trigger_topic_desc"}
        ]}, "description": "$pipeline_trigger_desc"},
        {"name": "steps", "type": {"type": "array", "items": [
          {"type": "record", "name": "PipelineStepCallTool", "fields": [
            {"name": "id", "type": "string", "description": "$pipeline_step_id_desc"},
            {"name": "type", "type": {"type": "enum", "name": "PipelineStepCallToolType", "symbols": ["call_tool"]}, "default": "call_tool", "description": "$pipeline_step_type_desc"},
            {"name": "tool", "type": "string", "description": "$pipeline_step_tool_desc"},
            {"name": "args", "type": {"type": "array", "items": "NameValueEntry"}, "default": [], "description": "$pipeline_step_args_desc"},
            {"name": "timeout_ms", "type": "int", "default": 60000, "description": "$pipeline_step_timeout_ms_desc"},
            {"name": "result_path", "type": "string", "default": "", "description": "$pipeline_step_result_path_desc"}
          ]},
          {"type": "record", "name": "PipelineStepLlmLoop", "fields": [
            {"name": "id", "type": "string", "description": "$pipeline_step_id_desc"},
            {"name": "type", "type": {"type": "enum", "name": "PipelineStepLlmLoopType", "symbols": ["llm_loop"]}, "default": "llm_loop", "description": "$pipeline_step_type_desc"},
            {"name": "provider_name", "type": "string", "description": "$pipeline_step_provider_name_desc"},
            {"name": "model", "type": "string", "description": "$pipeline_step_model_desc"},
            {"name": "key_expression", "type": "string", "default": "message.topic", "description": "$pipeline_step_key_expression_desc"},
            {"name": "persistent", "type": "boolean", "default": false, "description": "$pipeline_step_persistent_desc"},
            {"name": "max_tokens", "type": "int", "default": 2048, "description": "$pipeline_step_max_tokens_desc"},
            {"name": "max_total_tokens", "type": "int", "default": 50000, "description": "$pipeline_step_max_total_tokens_desc"},
            {"name": "timeout_ms", "type": "int", "default": 180000, "description": "$pipeline_step_timeout_ms_desc"},
            {"name": "tools", "type": {"type": "array", "items": "string"}, "default": [], "description": "$pipeline_step_tools_desc"},
            {"name": "instructions", "type": "string", "description": "$pipeline_step_instructions_desc"},
            {"name": "input", "type": {"type": "array", "items": "NameValueEntry"}, "default": [], "description": "$pipeline_step_input_desc"},
            {"name": "set_result_schema", "type": "string", "description": "$pipeline_step_set_result_schema_desc"},
            {"name": "result_path", "type": "string", "description": "$pipeline_step_result_path_desc"}
          ]},
          {"type": "record", "name": "PipelineStepBreak", "fields": [
            {"name": "id", "type": "string", "description": "$pipeline_step_id_desc"},
            {"name": "type", "type": {"type": "enum", "name": "PipelineStepBreakType", "symbols": ["break"]}, "default": "break", "description": "$pipeline_step_type_desc"},
            {"name": "path", "type": "string", "description": "$pipeline_step_path_desc"},
            {"name": "not", "type": "boolean", "default": false, "description": "$pipeline_step_not_desc"},
            {"name": "eq", "type": "string", "default": "true", "description": "$pipeline_step_eq_desc"}
          ]}
        ]}, "default": [], "description": "$pipeline_steps_desc"}
      ]}},
      "default": [],
      "description": "$pipelines_desc"
    }
  ]
}
