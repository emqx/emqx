%% -*- mode: erlang -*-
%%
%% In-tree EMQX plugin built by the umbrella app workflow.

{emqx_plugrel, [
    {authors, ["EMQX"]},
    {builder, [
        {name, "EMQX"},
        {contact, "developer@emqx.io"},
        {website, "https://www.emqx.com"}
    ]},
    {repo, "https://github.com/emqx/emqx"},
    {functionality, ["Cluster configuration synchronization"]},
    {compatibility, [{emqx, "~> 5.10"}]},
    {description, "Synchronize selected cluster configuration from a primary EMQX cluster."}
]}.
