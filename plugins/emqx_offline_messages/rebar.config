%% -*- mode: erlang -*-
%%
%% This plugin is an umbrella app of the EMQX monorepo — it is discovered
%% via `project_app_dirs/1` in the root `rebar.config.erl` and compiled
%% by the root `make`. CT runs via `make plugins/emqx_offline_messages-ct`
%% (handled by the generic `gen-app-ct-target` rule).
%%
%% Packaging is driven entirely from the umbrella build: `make
%% plugin-emqx_offline_messages` hands off to
%% `scripts/build-plugin.escript`, which reads the `emqx_plugrel`
%% metadata block below and the already-compiled beams from
%% `_build/$PROFILE/lib/emqx_offline_messages/` to produce
%% `_build/plugins/emqx_offline_messages-<vsn>.tar.gz`.
%%
%% Because the plugin is only built through the umbrella, this file
%% intentionally omits `deps`, `relx`, and build plugins — those would
%% only matter for a standalone `rebar3` invocation, which is no longer
%% part of the plugin build flow.

{emqx_plugrel, [
    {authors, ["EMQX"]},
    {builder, [
        {name, "EMQX"},
        {contact, "developer@emqx.io"},
        {website, "https://www.emqx.com"}
    ]},
    {repo, "https://github.com/emqx/emqx"},
    {functionality, ["Offline message persistence"]},
    {compatibility, [{emqx, "~> 5.10"}]},
    {description, "Offline message persistence plugin for EMQX."}
]}.
