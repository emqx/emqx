emqx_agent_schema {


    config {
        desc: "Agent plugin configuration."
        label: "Agent Config"
    }

    skill_entry {
        desc: "A registered skill instance as stored in the skill registry."
        label: "Skill Entry"
    }

    skill_publish_create {
        desc: "Parameters for registering a message.publish skill."
        label: "Publish Skill"
    }

    skill_mqtt_request_create {
        desc: "Parameters for registering a message.request skill."
        label: "Request Skill"
    }

    skill_http_create {
        desc: "Parameters for registering an HTTP skill."
        label: "HTTP Skill"
    }

    skill_postgresql_create {
        desc: """Parameters for registering a PostgreSQL query skill.
Provide a query using ${var} placeholders (e.g. SELECT * FROM t WHERE id = ${id}).
Placeholder names are extracted automatically, the input schema is generated from them,
and values are bound as PostgreSQL $1, $2, ... parameters when the skill is invoked.
No separate argument list or input schema is needed."""
        label: "PostgreSQL Skill"
    }

    connection_postgresql {
        desc: "A PostgreSQL skill connection configuration used by agent skills."
        label: "PostgreSQL Skill Connection"
    }

    connection_postgresql_config {
        desc: "PostgreSQL connection configuration."
        label: "PostgreSQL Connection Config"
    }

    pipeline {
        desc: "An event-driven pipeline definition that reacts to MQTT events and orchestrates skills and LLM sessions."
        label: "Pipeline"
    }

    pipeline_trigger {
        desc: "Trigger configuration for a pipeline — specifies the MQTT topic that activates a new instance."
        label: "Pipeline Trigger"
    }

    pipeline_step_call_skill {
        desc: "Pipeline step that invokes a registered skill."
        label: "Call Skill Step"
    }

    pipeline_step_llm_loop {
        desc: "Pipeline step that runs an LLM session loop."
        label: "LLM Loop Step"
    }

    pipeline_step_wait_for_event {
        desc: "Pipeline step that waits for a matching MQTT event."
        label: "Wait For Event Step"
    }

    pipeline_step_break {
        desc: "Pipeline step that stops execution when a condition matches."
        label: "Break Step"
    }

    name_value_entry {
        desc: "A strict name/value entry used where arbitrary map keys would otherwise be needed."
        label: "Name Value Entry"
    }

    ## ── skill_entry fields ───────────────────────────────────────────────────

    skill_entry_id {
        desc: "Skill instance ID in the registry."
        label: "Skill ID"
    }

    skill_entry_type {
        desc: "Skill type identifier (e.g. message.publish, message.request, http, postgresql.query)."
        label: "Skill Type"
    }

    skill_entry_display_name {
        desc: "Human-readable display name for the skill."
        label: "Display Name"
    }

    skill_entry_description {
        desc: "Description exposed to the LLM as part of the tool manifest."
        label: "Description"
    }

    skill_entry_input_schema {
        desc: "JSON Schema describing the skill input arguments."
        label: "Input Schema"
    }

    skill_entry_output_schema {
        desc: "JSON Schema describing the skill response shape."
        label: "Output Schema"
    }

    ## ── Shared create-variant fields ─────────────────────────────────────────

    skill_type_discriminator {
        desc: "Skill type discriminator — selects the skill implementation."
        label: "Type"
    }

    skill_id {
        desc: "Unique skill instance ID."
        label: "Skill ID"
    }

    skill_human_desc {
        desc: "Human-readable description of the skill."
        label: "Description"
    }

    skill_input_schema {
        desc: "JSON Schema for the skill input arguments."
        label: "Input Schema"
    }

    skill_output_schema {
        desc: "JSON Schema for the skill response."
        label: "Output Schema"
    }

    ## ── skill_publish_create ─────────────────────────────────────────────────

    skill_publish_topic_prefix.desc:
"""MQTT topic prefix prepended to every agent-supplied topic suffix.
Constrains the skill to a specific namespace."""

    skill_publish_topic_prefix.label:
"""Topic Prefix"""

    ## ── skill_mqtt_request_create ────────────────────────────────────────────

    skill_request_payload_schema.desc:
"""JSON Schema describing the request payload the LLM should send.
When omitted, the payload field is described as an untyped JSON value."""

    skill_request_payload_schema.label:
"""Request Payload Schema"""

    skill_response_schema.desc:
"""JSON Schema describing the response payload the LLM will receive.
When omitted, the payload field is described as an untyped JSON value."""

    skill_response_schema.label:
"""Response Payload Schema"""

    ## ── skill_http_create ────────────────────────────────────────────────────

    skill_http_method {
        desc: "HTTP method used when invoking the skill."
        label: "HTTP Method"
    }

    skill_http_url.desc:
"""Base URL of the remote endpoint.
Query string is appended for GET; JSON body is sent for POST/PUT/PATCH/DELETE."""

    skill_http_url.label:
"""URL"""

    skill_http_headers {
        desc: "Static HTTP headers sent with every request."
        label: "Headers"
    }

    ## ── skill_postgresql_create ───────────────────────────────────────────────

    skill_pg_query.desc:
"""PostgreSQL SQL query template.
Use ${var} placeholders. The skill extracts placeholder names, generates its input schema,
and binds values to PostgreSQL $1, $2, ... parameters when invoked."""

    skill_pg_query.label:
"""Query Template"""

    skill_pg_resource.desc:
"""Connection ID of the PostgreSQL connection used when invoking this skill.
Disabled connections are allowed but invocations will fail until the connection is enabled."""

    skill_pg_resource.label:
"""Connection"""

    ## ── connections ──────────────────────────────────────────────────────────

    config_skills {
        desc: "Configured skill definitions."
        label: "Skills"
    }

    config_connections {
        desc: "Skill connection configurations."
        label: "Connections"
    }

    connection_id {
        desc: "Unique connection ID."
        label: "Connection ID"
    }

    connection_type {
        desc: "Connection type. Currently only postgresql is supported."
        label: "Connection Type"
    }

    connection_enable {
        desc: "Whether this connection resource should be started on each node."
        label: "Enabled"
    }

    connection_config {
        desc: "Connector-specific connection settings."
        label: "Config"
    }

    ## ── meta-skill create variants ───────────────────────────────────────────

    skill_create_skill_create {
        desc: "Parameters for registering an agent.create_skill meta-skill."
        label: "Create Skill Meta-Skill"
    }

    skill_create_pipeline_create {
        desc: "Parameters for registering an agent.create_pipeline meta-skill."
        label: "Create Pipeline Meta-Skill"
    }

    skill_query_skills_create {
        desc: "Parameters for registering an agent.query_skills meta-skill."
        label: "Query Skills Meta-Skill"
    }

    skill_query_providers_create {
        desc: "Parameters for registering an agent.query_providers meta-skill."
        label: "Query Providers Meta-Skill"
    }

    skill_query_pipelines_create {
        desc: "Parameters for registering an agent.query_pipelines meta-skill."
        label: "Query Pipelines Meta-Skill"
    }

    skill_delete_skill_create {
        desc: "Parameters for registering an agent.delete_skill meta-skill."
        label: "Delete Skill Meta-Skill"
    }

    skill_delete_pipeline_create {
        desc: "Parameters for registering an agent.delete_pipeline meta-skill."
        label: "Delete Pipeline Meta-Skill"
    }

    ## ── pipeline fields ──────────────────────────────────────────────────────

    pipeline_id {
        desc: "Unique pipeline definition identifier."
        label: "Pipeline ID"
    }

    pipeline_active {
        desc: "When true, the pipeline runtime subscribes to the trigger topic and spawns instances on matching events. Set to false to disable without deleting."
        label: "Active"
    }

    pipeline_trigger_field {
        desc: "Trigger configuration — defines which MQTT event activates this pipeline."
        label: "Trigger"
    }

    pipeline_steps.desc:
"""Ordered list of step definitions.
Each step must have a type field: call_skill | wait_for_event | llm_loop | branch."""

    pipeline_steps.label:
"""Steps"""

    ## ── pipeline_trigger fields ──────────────────────────────────────────────

    pipeline_trigger_topic.desc:
"""MQTT topic filter (supports + and # wildcards) that activates a new pipeline instance
when a matching message is published."""

    pipeline_trigger_topic.label:
"""Topic Filter"""

    ## ── pipeline step fields ─────────────────────────────────────────────────

    pipeline_step_id {
        desc: "Unique step identifier within this pipeline."
        label: "Step ID"
    }

    pipeline_step_type {
        desc: "Pipeline step type discriminator."
        label: "Step Type"
    }

    pipeline_step_skill {
        desc: "Skill reference as type@skill_id."
        label: "Skill"
    }

    pipeline_step_args {
        desc: "Argument entries passed to the skill. Values starting with $. are resolved from pipeline context."
        label: "Arguments"
    }

    pipeline_step_result_path {
        desc: "Context path where the step result is written."
        label: "Result Path"
    }

    pipeline_step_provider_name {
        desc: "Name of a configured AI provider."
        label: "Provider Name"
    }

    pipeline_step_model {
        desc: "LLM model name."
        label: "Model"
    }

    pipeline_step_stop_on_finish {
        desc: "When true, the session terminates after publishing final; when false, it remains persistent."
        label: "Stop On Finish"
    }

    pipeline_step_max_tokens {
        desc: "Maximum completion tokens."
        label: "Max Tokens"
    }

    pipeline_step_tools {
        desc: "Skill references exposed as tools to the LLM. Include every skill the LLM step must call directly while reasoning; use later call_skill steps only for actions that should happen after the LLM returns its structured result."
        label: "Tools"
    }

    pipeline_step_instructions {
        desc: "System prompt for the LLM."
        label: "Instructions"
    }

    pipeline_step_input {
        desc: "Input entries sent as the first user message. Values starting with $. are resolved from context."
        label: "Input"
    }

    pipeline_step_set_result_schema {
        desc: "JSON Schema for structured output via the built-in set_result tool, encoded as a JSON string."
        label: "Set Result Schema"
    }

    pipeline_step_topic {
        desc: "MQTT topic filter to wait on."
        label: "Topic"
    }

    pipeline_step_where {
        desc: "Optional filter expression for a waited event."
        label: "Where"
    }

    pipeline_step_path {
        desc: "JSONPath into context to evaluate."
        label: "Path"
    }

    pipeline_step_not {
        desc: "Negate the break condition."
        label: "Not"
    }

    pipeline_step_eq {
        desc: "Primitive value to compare against."
        label: "Equals"
    }

    name_value_entry_name {
        desc: "Entry name."
        label: "Name"
    }

    name_value_entry_value {
        desc: "Entry primitive value."
        label: "Value"
    }

}
