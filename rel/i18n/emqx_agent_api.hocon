emqx_agent_api {

    ## UI

    ui_get {
        desc: "Agent management UI — single-page application for managing skills, AI providers, and pipelines."
        label: "Agent UI"
    }

    demo_storage_ui_get {
        desc: "Demo storage-facility UI — single-page simulation for device telemetry, commands, and pipeline governance."
        label: "Demo Storage UI"
    }

    builder_ui_get {
        desc: "Pipeline Builder demo UI — conversational chat interface for creating and managing EMQX Agent pipelines via an LLM."
        label: "Pipeline Builder UI"
    }

    apple_box_ui_get {
        desc: "Apple Box Conveyor demo UI — single-page simulation for visual quality inspection of apple boxes via LLM pipeline."
        label: "Apple Box Conveyor UI"
    }

    apple_box_img_get {
        desc: "Static image asset for the Apple Box Conveyor demo (box, fresh apple, rotten apple sprites)."
        label: "Apple Box Image Asset"
    }

    ## Skills collection

    skills_list {
        desc: "List all registered skill instances."
        label: "List Skills"
    }

    skills_create {
        desc: "Register a new skill instance. The `type` field selects the implementation: message.publish | http | kv | postgresql.query."
        label: "Create Skill"
    }

    ## Individual skill

    skill_get {
        desc: "Get a registered skill instance by type and ID."
        label: "Get Skill"
    }

    skill_put {
        desc: "Replace a skill instance. The type and ID are taken from the URL; the body must contain a complete skill definition of the same type."
        label: "Update Skill"
    }

    skill_delete {
        desc: "Unregister a skill instance."
        label: "Delete Skill"
    }

    ## Path parameter descriptions

    param_skill_type {
        desc: "Registry skill type: message.publish | message.request | http | postgresql.query."
        label: "Skill Type"
    }

    param_skill_id {
        desc: "Skill instance ID."
        label: "Skill ID"
    }

    param_pipeline_id {
        desc: "Pipeline definition ID."
        label: "Pipeline ID"
    }

    ## Error descriptions

    skill_bad_request {
        desc: "Invalid or incomplete skill configuration."
        label: "Skill Bad Request"
    }

    skill_not_found {
        desc: "Skill not found."
        label: "Skill Not Found"
    }

    profile_bad_request {
        desc: "Missing required fields."
        label: "Profile Bad Request"
    }

    profile_not_found {
        desc: "Session profile not found."
        label: "Profile Not Found"
    }

    pipeline_bad_request {
        desc: "Invalid pipeline definition."
        label: "Pipeline Bad Request"
    }

    pipeline_not_found {
        desc: "Pipeline not found."
        label: "Pipeline Not Found"
    }

    ## Pipelines collection

    pipelines_list {
        desc: "List all registered pipeline definitions."
        label: "List Pipelines"
    }

    pipelines_create {
        desc: "Register a pipeline definition. Once registered, the pipeline runtime will start a new instance whenever a message is published on the trigger topic."
        label: "Create Pipeline"
    }

    ## Individual pipeline

    pipeline_get {
        desc: "Get a pipeline definition by ID."
        label: "Get Pipeline"
    }

    pipeline_put {
        desc: "Replace a pipeline definition."
        label: "Update Pipeline"
    }

    pipeline_delete {
        desc: "Unregister a pipeline definition."
        label: "Delete Pipeline"
    }

}
